# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DATABASE_URL=postgresql://trackroute:trackroute_pass@localhost:5433/trackroute_db

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=8h

# SOAP Tracking Service
SOAP_TRACKING_URL=http://localhost:8080/tracking?wsdl
SOAP_CACHE_TTL_SECONDS=60

# CORS
CORS_ORIGIN=http://localhost:4200

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
